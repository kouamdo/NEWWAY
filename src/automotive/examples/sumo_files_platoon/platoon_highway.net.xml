<?xml version="1.0" encoding="UTF-8"?>
<!--
  Straight 3-lane highway (2 km) for platoon emergency braking experiments.
  Speed limit 120 km/h (33.33 m/s).
  3 lanes: lane 0 (right/slow), lane 1 (middle), lane 2 (left/fast).
-->
<net version="1.6" junctionCornerDetail="5" limitTurnSpeed="5.50"
     xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
     xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/net_file.xsd">

    <location netOffset="0.00,0.00" convBoundary="0.00,0.00,2000.00,20.00"
              origBoundary="0,0,2000,20" projParameter="!"/>

    <!-- Main highway segment -->
    <edge id="highway" from="start" to="end" priority="3">
        <lane id="highway_0" index="0" speed="33.33" length="2000.00" shape="0.00,1.60 2000.00,1.60"/>
        <lane id="highway_1" index="1" speed="33.33" length="2000.00" shape="0.00,4.80 2000.00,4.80"/>
        <lane id="highway_2" index="2" speed="33.33" length="2000.00" shape="0.00,8.00 2000.00,8.00"/>
    </edge>

    <!-- Return edge (for continuous simulation if needed) -->
    <edge id="return" from="end" to="start" priority="1" shape="2000.00,15.00 1000.00,18.00 0.00,15.00">
        <lane id="return_0" index="0" speed="33.33" length="2010.00" shape="2000.00,15.00 1000.00,18.00 0.00,15.00"/>
    </edge>

    <junction id="start" type="dead_end" x="0.00" y="5.00" incLanes="return_0" intLanes=""
              shape="0.00,9.60 0.00,0.00"/>
    <junction id="end" type="dead_end" x="2000.00" y="5.00" incLanes="highway_0 highway_1 highway_2" intLanes=""
              shape="2000.00,0.00 2000.00,9.60"/>

</net>
