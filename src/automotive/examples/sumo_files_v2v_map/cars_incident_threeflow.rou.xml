<routes>
  <route id="r_main" edges="nw_to_sw sw_to_se se_to_ne ne_to_nw"/>

  <!-- Emergency lead vehicle (incident source) -->
  <vType id="EmergencyLead" vClass="emergency" accel="4.0" decel="7.0" emergencyDecel="9.0" sigma="0.0" tau="0.6" minGap="1.0" maxSpeed="24.0"/>

